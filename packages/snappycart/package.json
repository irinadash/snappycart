{
  "name": "snappycart",
  "private": false,
  "version": "1.2.0",
  "type": "module",
  "description": "A lightweight, embeddable React cart component with context support",
  "module": "dist/index.js",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "cart",
    "shopping",
    "context",
    "checkout"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/idncod/snappycart"
  },
  "scripts": {
    "build:lib": "tsup src/index.ts --format esm,cjs --dts --clean --tsconfig tsconfig.tsup.json",
    "build:styles": "sass src/cart/components/snappycart.scss dist/styles.css --no-source-map",
    "build": "npm run build:lib && npm run build:styles",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "jsdom": "^26.0.0",
    "sass": "^1.86.3",
    "tsup": "^8.5.1",
    "vitest": "^3.1.1"
  }
}