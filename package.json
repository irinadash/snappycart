{
  "name": "snappycart-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm test --workspace=snappycart",
    "dev:demo": "npm run dev --workspace=demo",
    "dev:docs": "npm run dev --workspace=documentation",
    "build:package": "npm run build --workspace=snappycart",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "test:cypress": "cypress run",
    "test:cypress:component": "cypress run --component",
    "test:cypress:e2e": "cypress run --e2e",
    "test:playwright": "playwright test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.21.0",
    "@playwright/experimental-ct-react": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "cypress": "^15.10.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1"
  },
  "lint-staged": {
    "packages/snappycart/src/**/*.{ts,tsx,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/**/*.{ts,tsx,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}